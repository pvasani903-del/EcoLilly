@model EcoLilly.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
}

<style>
    .metric-card { border-radius: 12px; border: 1px solid #eef2f5; background: #fff; padding: 20px; transition: 0.3s; }
    .icon-box { width: 50px; height: 50px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; }
</style>

<div class="row g-4 mb-4">
    <!-- Products -->
    <div class="col-md-3">
        <div class="metric-card shadow-sm d-flex justify-content-between align-items-center">
            <div>
                <div class="text-muted small fw-bold mb-1">TOTAL PRODUCTS</div>
                <h3 class="fw-bold text-success mb-0">@Model.TotalProducts</h3>
            </div>
            <div class="icon-box bg-success bg-opacity-10 text-success">
                <i class="bi bi-box-seam"></i>
            </div>
        </div>
    </div>

    <!-- Orders -->
    <div class="col-md-3">
        <div class="metric-card shadow-sm d-flex justify-content-between align-items-center">
            <div>
                <div class="text-muted small fw-bold mb-1">TOTAL ORDERS</div>
                <h3 class="fw-bold text-primary mb-0">@Model.TotalOrders</h3>
            </div>
            <div class="icon-box bg-primary bg-opacity-10 text-primary">
                <i class="bi bi-bag-check"></i>
            </div>
        </div>
    </div>

    <!-- Customers -->
    <div class="col-md-3">
        <div class="metric-card shadow-sm d-flex justify-content-between align-items-center">
            <div>
                <div class="text-muted small fw-bold mb-1">ACTIVE CUSTOMERS</div>
                <h3 class="fw-bold text-purple mb-0" style="color: #6f42c1;">@Model.TotalUsers</h3>
            </div>
            <div class="icon-box bg-opacity-10" style="background-color: rgba(111,66,193,0.1); color: #6f42c1;">
                <i class="bi bi-people"></i>
            </div>
        </div>
    </div>

    <!-- Revenue -->
    <div class="col-md-3">
        <div class="metric-card shadow-sm d-flex justify-content-between align-items-center">
            <div>
                <div class="text-muted small fw-bold mb-1">TOTAL REVENUE</div>
                <h3 class="fw-bold text-danger mb-0" style="color: #e5652e !important;">₹@Model.TotalRevenue.ToString("0.00")</h3>
            </div>
            <div class="icon-box bg-opacity-10" style="background-color: rgba(229,101,46,0.1); color: #e5652e;">
                <i class="bi bi-graph-up-arrow"></i>
            </div>
        </div>
    </div>
</div>

<!-- CHARTS ROW -->
<div class="row g-4">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 d-flex justify-content-between">
                <h5 class="fw-bold"><i class="bi bi-graph-up text-primary me-2"></i> Weekly Sales Overview</h5>
                <select class="form-select form-select-sm w-auto"><option>Last 7 days</option></select>
            </div>
            <div class="card-body px-4 pb-4">
                <canvas id="salesChart" height="100"></canvas>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card shadow-sm border-0 rounded-4 h-100">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <h5 class="fw-bold"><i class="bi bi-leaf text-success me-2"></i> Top Products</h5>
            </div>
            <div class="card-body px-4 text-muted text-center pt-5">
                No product sales data available yet.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var ctx = document.getElementById('salesChart').getContext('2d');
        var salesChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.OrdersByDayLabels)),
                datasets: [{
                    label: 'Revenue (₹)',
                    data: @Html.Raw(Json.Serialize(Model.OrdersByDayTotals)),
                    borderColor: '#21a345',
                    backgroundColor: 'rgba(33, 163, 69, 0.1)',
                    borderWidth: 3,
                    pointBackgroundColor: '#21a345',
                    pointRadius: 4,
                    fill: true,
                    tension: 0.3
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { borderDash: [5, 5] } },
                    x: { grid: { display: false } }
                }
            }
        });
    </script>
}