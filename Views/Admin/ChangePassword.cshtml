@{
    ViewData["Title"] = "Change Password";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0 fw-bold text-success">Change Admin Password</h5>
    </div>
    <div class="card-body p-4">

        @if (!string.IsNullOrEmpty(ViewBag.Error))
        {
            <div class="alert alert-danger py-2">@ViewBag.Error</div>
        }
        @if (!string.IsNullOrEmpty(ViewBag.Success))
        {
            <div class="alert alert-success py-2">@ViewBag.Success</div>
        }

        <form asp-controller="Admin" asp-action="ChangePassword" method="post" style="max-w-md;">

            <div class="mb-3">
                <label class="form-label fw-bold text-secondary">Current Password</label>
                <input type="password" name="currentPassword" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold text-secondary">New Password</label>
                <input type="password" name="newPassword" class="form-control" required />
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold text-secondary">Confirm New Password</label>
                <input type="password" name="confirmPassword" class="form-control" required />
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn btn-success px-4 py-2 fw-bold text-white shadow-sm">Update Password</button>
                <a asp-controller="Admin" asp-action="Index" class="btn btn-light border px-4 py-2 fw-bold text-secondary shadow-sm">Back to Dashboard</a>
            </div>

        </form>

    </div>
</div>