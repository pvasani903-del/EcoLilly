@model IEnumerable<EcoLilly.Models.Contact>
@{
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Contact Messages</h4>
    <a class="btn btn-primary" asp-controller="AdminContact" asp-action="Create">Add Message</a>
</div>

<form method="get" class="mb-3">
    <div class="input-group">
        <input name="search" value="@Context.Request.Query["search"]" class="form-control" placeholder="Search name, email or subject..." />
        <button class="btn btn-outline-secondary">Search</button>
    </div>
</form>

@if (TempData["success"] != null)
{
    <div class="alert alert-success">@TempData["success"]</div>
}

<table class="table table-striped table-responsive">
    <thead>
        <tr>
            <th>#</th>
            <th>Name</th>
            <th>Email</th>
            <th>Subject</th>
            <th class="text-truncate">Message</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6" class="text-center text-muted">No messages found</td>
            </tr>
        }
        else
        {
            foreach (var m in Model)
            {
                <tr>
                    <td>@m.Id</td>
                    <td>@m.Name</td>
                    <td>@m.Email</td>
                    <td>@m.Subject</td>
                    <td style="max-width:360px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@m.Message</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-info me-1" asp-controller="AdminContact" asp-action="Details" asp-route-id="@m.Id">View</a>
                        <a class="btn btn-sm btn-warning me-1" asp-controller="AdminContact" asp-action="Edit" asp-route-id="@m.Id">Edit</a>

                        <form asp-controller="AdminContact" asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this message?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@m.Id" />
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>