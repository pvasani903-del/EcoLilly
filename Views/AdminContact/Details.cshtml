@model EcoLilly.Models.Contact
@{
    Layout = "_AdminLayout";
}
<h4>Contact Message</h4>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">@Model.Subject</h5>
        <h6 class="card-subtitle mb-2 text-muted">From: @Model.Name • @Model.Email</h6>
        <p class="card-text">@Model.Message</p>
        <div class="mt-3">
            <a class="btn btn-secondary" asp-controller="AdminContact" asp-action="Index">Back</a>
            <a class="btn btn-danger" asp-controller="AdminContact" asp-action="Delete" asp-route-id="@Model.Id" onclick="return confirm('Delete this message?');">Delete</a>
        </div>
    </div>
</div>