@{
    ViewData["Title"] = "Change Password";
}

<div class="max-w-md mx-auto mt-10 p-6 bg-white rounded-lg shadow">
    <h1 class="text-2xl font-bold mb-4">Change Password</h1>

    @if (ViewBag.Error != null)
    {
        <div class="mb-4 text-red-600 font-medium">@ViewBag.Error</div>
    }
    @if (ViewBag.Success != null)
    {
        <div class="mb-4 text-green-600 font-medium">@ViewBag.Success</div>
    }

    <form asp-action="ChangePassword" method="post" class="space-y-4">
        <div>
            <label class="block font-medium mb-1">Current Password</label>
            <input type="password" name="currentPassword" class="w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-green-500" />
        </div>

        <div>
            <label class="block font-medium mb-1">New Password</label>
            <input type="password" name="newPassword" class="w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-green-500" />
        </div>

        <div>
            <label class="block font-medium mb-1">Confirm New Password</label>
            <input type="password" name="confirmPassword" class="w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-green-500" />
        </div>

        <button type="submit" class="w-full bg-green-600 text-white py-2 rounded hover:bg-green-700">Change Password</button>
    </form>
</div>