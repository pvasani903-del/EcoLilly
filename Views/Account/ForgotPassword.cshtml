@{
    ViewData["Title"] = "Forgot Password";
}

<section class="min-h-screen flex items-center justify-center bg-gradient-to-br from-green-50 to-emerald-100">

    <div class="bg-white shadow-xl rounded-xl p-10 w-full max-w-md">

        <h2 class="text-2xl font-bold mb-6 text-center text-gray-800">
            Reset Your Password
        </h2>

        @if (ViewBag.Message != null)
        {
            <div class="bg-green-100 text-green-600 p-3 rounded mb-4">
                @ViewBag.Message
            </div>
        }

        @if (ViewBag.Error != null)
        {
            <div class="bg-red-100 text-red-600 p-3 rounded mb-4">
                @ViewBag.Error
            </div>
        }

        <form method="post">
            <div class="mb-4">
                <label class="block font-semibold mb-1">Enter Your Email</label>
                <input type="email" name="email"
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-500"
                       required />
            </div>

            <button type="submit"
                    class="w-full bg-green-600 text-white py-2 rounded-lg hover:bg-green-700">
                Send Reset Link
            </button>
        </form>

        <div class="mt-4 text-center">
            <a asp-action="Login" class="text-sm text-green-600 hover:underline">
                Back to Login
            </a>
        </div>

    </div>
</section>