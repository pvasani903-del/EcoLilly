@model EcoLilly.Models.User

@{
    ViewData["Title"] = "Register";
}

<section class="py-10 bg-gradient-to-br from-green-50 to-emerald-100 min-h-screen flex items-center justify-center">

    <div class="bg-white rounded-xl shadow-2xl overflow-hidden flex flex-row w-full max-w-6xl">

        <!-- LEFT PANEL -->
        <div class="w-2/5 bg-gradient-to-br from-green-700 via-emerald-600 to-green-800 text-white flex flex-col items-center justify-center text-center p-10">

            <h2 class="text-4xl font-extrabold mb-4">
                EcoLiving 🌿
            </h2>
           
            <div class="w-20 h-1 bg-white rounded-full mb-6"></div>

            <img src="~/images/img.jpg"
                 class="w-64 h-44 object-cover rounded-xl shadow-2xl mb-6 border-4 border-white" />

            <p class="text-emerald-100 text-sm leading-relaxed max-w-xs">
                Join our eco-friendly community and start your sustainable journey today.
            </p>

        </div>

        <!-- RIGHT PANEL -->
        <div class="w-3/5 p-10">

            <h2 class="text-2xl font-bold mb-6 text-green-700">
                Create Account
            </h2>

            <form asp-controller="Account"
                  asp-action="Register"
                  method="post"
                  enctype="multipart/form-data"
                  class="space-y-4">

                <!-- NAME -->
                <div>
                    <label class="font-semibold">Full Name</label>

                    <input asp-for="Name"
                           class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-green-400 outline-none" />

                    <span asp-validation-for="Name" class="text-red-500 text-sm"></span>

                </div>

                <!-- EMAIL -->
                <div>

                    <label class="font-semibold">Email</label>

                    <input asp-for="Email"
                           type="email"
                           class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-green-400 outline-none" />

                    <span asp-validation-for="Email" class="text-red-500 text-sm"></span>

                </div>

                <!-- PASSWORD -->
                <div class="relative">

                    <label class="font-semibold">Password</label>

                    <input asp-for="Password"
                           type="password"
                           id="registerPassword"
                           class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-green-400 outline-none" />

                    <button type="button"
                            onclick="toggleRegisterPassword()"
                            class="absolute right-3 top-8 text-gray-500">
                        👁
                    </button>

                    <span asp-validation-for="Password" class="text-red-500 text-sm"></span>

                </div>

                <!-- PHONE -->
                <div>

                    <label class="font-semibold">Phone</label>

                    <input asp-for="Phone"
                           class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-green-400 outline-none" />

                    <span asp-validation-for="Phone" class="text-red-500 text-sm"></span>

                </div>

                <!-- ADDRESS -->
                <div>

                    <label class="font-semibold">Address</label>

<textarea asp-for="Address"
          rows="3"
          class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-green-400 outline-none"></textarea>

                    <span asp-validation-for="Address" class="text-red-500 text-sm"></span>

                </div>

                <!-- PROFILE PHOTO -->
                <div>

                    <label class="font-semibold">Profile Photo</label>

                    <input type="file"
                           name="profilePhoto"
                           class="w-full border p-2 rounded-lg bg-gray-50" />

                </div>

                <button type="submit"
                        class="w-full bg-gradient-to-r from-green-600 to-emerald-600 text-white py-2 rounded-lg font-bold hover:scale-105 transition">
                    Create Account
                </button>

            </form>

            <div class="mt-6 text-center text-sm">

                Already have an account?

                <a asp-controller="Account"
                   asp-action="Login"
                   class="text-green-600 font-bold hover:underline">
                    Sign In
                </a>

            </div>

        </div>

    </div>

</section>

<script>
    function toggleRegisterPassword() {
    var input = document.getElementById("registerPassword");
    input.type = input.type === "password" ? "text" : "password";
    }
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}