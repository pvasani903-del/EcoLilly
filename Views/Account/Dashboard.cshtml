@model EcoLilly.Models.DashboardViewModel
@{
    ViewData["Title"] = "My Account";
}

<div class="max-w-7xl mx-auto py-10 px-6">

    <!-- Welcome Section -->

    <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-8">

        <h2 class="text-2xl font-bold text-green-700">
            Welcome, @Model.User.Name 👋
        </h2>

        <p class="text-gray-600 mt-1">
            Manage your orders, wishlist and account details here.
        </p>
       
    </div>

    <!-- Account Options -->

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">

        <div class="bg-white shadow-md rounded-lg p-6 text-center hover:shadow-lg transition">

            <h3 class="text-lg font-semibold text-gray-700 mb-2">
                My Cart
            </h3>

            <p class="text-3xl font-bold text-green-600">
                @Model.CartCount
            </p>

            <p class="text-gray-500">Items</p>

            <a asp-controller="Cart" asp-action="Index"
               class="inline-block mt-3 text-green-600 font-semibold hover:underline">
                View Cart
            </a>

        </div>

        <div class="bg-white shadow-md rounded-lg p-6 text-center hover:shadow-lg transition">

            <h3 class="text-lg font-semibold text-gray-700 mb-2">
                Wishlist
            </h3>

            <p class="text-3xl font-bold text-pink-500">
                @Model.WishlistCount
            </p>

            <p class="text-gray-500">Saved Items</p>

            <a asp-controller="Wishlist" asp-action="Index"
               class="inline-block mt-3 text-pink-500 font-semibold hover:underline">
                View Wishlist
            </a>

        </div>

        <div class="bg-white shadow-md rounded-lg p-6 text-center hover:shadow-lg transition">

            <h3 class="text-lg font-semibold text-gray-700 mb-2">
                Orders
            </h3>

            <p class="text-3xl font-bold text-blue-600">
                @Model.RecentOrders.Count
            </p>

            <p class="text-gray-500">Recent Orders</p>

            <a asp-controller="Order" asp-action="Index"
               class="inline-block mt-3 text-blue-600 font-semibold hover:underline">
                View Orders
            </a>

        </div>

    </div>

    <!-- Account Settings -->

    <div class="bg-white shadow-md rounded-lg p-6 mb-10">

        <h3 class="text-xl font-semibold mb-4">Account Settings</h3>

        <div class="flex flex-wrap gap-4">

            <a asp-controller="Account" asp-action="EditProfile"
               class="px-5 py-2 bg-green-600 text-white rounded hover:bg-green-700">
                Edit Profile
            </a>

            <a asp-controller="Account" asp-action="ChangePassword"
               class="px-5 py-2 bg-yellow-500 text-white rounded hover:bg-yellow-600">
                Change Password
            </a>

            <a asp-controller="Account" asp-action="Logout"
               class="px-5 py-2 bg-red-500 text-white rounded hover:bg-red-600">
                Logout
            </a>

        </div>

    </div>

    <!-- Recent Orders -->

    <div class="bg-white shadow-md rounded-lg p-6">

        <h3 class="text-xl font-semibold mb-4">Recent Orders</h3>

        <table class="w-full border">

            <thead class="bg-gray-100">

                <tr>

                    <th class="p-3 text-left">Order #</th>
                    <th class="p-3 text-left">Date</th>
                    <th class="p-3 text-left">Total</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var order in Model.RecentOrders)
                {
                    <tr class="border-t">

                        <td class="p-3">#@order.Id</td>

                        <td class="p-3">
                            @order.OrderDate.ToString("yyyy-MM-dd")
                        </td>

                        <td class="p-3 font-semibold text-green-600">
                            ₹@order.TotalAmount
                        </td>

                    </tr>
                }

                @if (!Model.RecentOrders.Any())
                {
                    <tr>

                        <td colspan="3" class="p-4 text-center text-gray-500">
                            No recent orders
                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>