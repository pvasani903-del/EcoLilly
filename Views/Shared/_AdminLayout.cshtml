@using Microsoft.AspNetCore.Http
@{
    var adminName = Context.Session.GetString("AdminName") ?? "Admin";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string Active(string ctrl) => string.Equals(ctrl, currentController, System.StringComparison.OrdinalIgnoreCase) ? "active bg-success text-white rounded" : "text-white-50";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Admin • EcoLilly</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { background-color: #f4f7f6; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .sidebar { background-color: #1e2433; width: 250px; min-height: 100vh; display: flex; flex-direction: column; }
        .nav-link:hover { background-color: rgba(255,255,255,0.1); border-radius: 5px; color: white !important;}
        .page-area { flex-grow: 1; display: flex; flex-direction: column; }
        .top-navbar { background-color: #21a345; color: white; }
        .logout-btn { background-color: #2a303f; color: #ffcccc; border-radius: 8px; text-align: left; padding: 10px 15px; border: none; width: 100%; transition: 0.3s; }
        .logout-btn:hover { background-color: #3b4155; color: white; }
    </style>
</head>
<body class="d-flex m-0 p-0">

    <!-- SIDEBAR -->
    <nav class="sidebar p-3 shadow-lg">
        <a class="text-decoration-none text-white mb-4 mt-2 d-flex align-items-center gap-2" asp-controller="Admin" asp-action="Index">
            <i class="bi bi-leaf text-success fs-3"></i>
            <div>
                <div class="fs-5 fw-bold lh-1 text-white">EcoLilly</div>
                <small class="text-white-50" style="font-size: 11px;">Admin Panel</small>
            </div>
        </a>

        <ul class="nav flex-column gap-1 mb-auto">
            <li class="nav-item">
                <a class="nav-link px-3 @Active("Admin")" asp-controller="Admin" asp-action="Index"><i class="bi bi-grid-1x2 me-2"></i> Dashboard</a>
            </li>
            <li class="nav-item">
                <a class="nav-link px-3 @Active("AdminProduct")" asp-controller="AdminProduct" asp-action="Index"><i class="bi bi-box-seam me-2"></i> Products</a>
            </li>
            
            <!-- Added Orders -->
            <li class="nav-item">
                <a class="nav-link px-3 @Active("AdminOrder")" asp-controller="AdminOrder" asp-action="Index"><i class="bi bi-bag-check me-2"></i> Orders</a>
            </li>

            <!-- Renamed to Cart -->
            <li class="nav-item">
                <a class="nav-link px-3 @Active("AdminCart")" asp-controller="AdminCart" asp-action="Index"><i class="bi bi-cart3 me-2"></i> Cart</a>
            </li>
            
            <!-- Added Wishlists -->
            <li class="nav-item">
                <a class="nav-link px-3 @Active("AdminWishlist")" asp-controller="AdminWishlist" asp-action="Index"><i class="bi bi-heart me-2"></i> Wishlists</a>
            </li>

            <!-- Added Reviews -->
            <li class="nav-item">
                <a class="nav-link px-3 @Active("AdminReview")" asp-controller="AdminReview" asp-action="Index"><i class="bi bi-star me-2"></i> Reviews</a>
            </li>

            <li class="nav-item">
                <a class="nav-link px-3 @Active("AdminUser")" asp-controller="AdminUser" asp-action="Index"><i class="bi bi-people me-2"></i> Customers</a>
            </li>
            <li class="nav-item">
                <a class="nav-link px-3 @Active("AdminDiscount")" asp-controller="AdminDiscount" asp-action="Index"><i class="bi bi-tags me-2"></i> Offers</a>
            </li>
            
            <!-- Change Password -->
            <li class="nav-item mt-4">
                <a class="nav-link px-3 @Active("ChangePassword")" asp-controller="Admin" asp-action="ChangePassword"><i class="bi bi-key me-2"></i> Change Password</a>
            </li>
        </ul>

        <!-- LOGOUT -->
        <div class="mt-4 pt-3 border-top border-secondary border-opacity-25">
            <form asp-controller="Admin" asp-action="Logout" method="post" class="m-0">
                <button type="submit" class="logout-btn"><i class="bi bi-box-arrow-right me-2"></i> Logout</button>
            </form>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <div class="page-area">
        <!-- HEADER -->
        <nav class="navbar top-navbar px-4 py-3 shadow-sm">
            <div>
                <h5 class="mb-0 fw-bold">EcoLilly Admin</h5>
                <small class="text-white-50">Welcome back, @adminName</small>
            </div>
            <div>
                 <i class="bi bi-person-circle fs-4"></i>
            </div>
        </nav>

        <!-- DASHBOARD BODY -->
        <main class="container-fluid p-4">
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>