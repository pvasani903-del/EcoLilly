@model EcoLilly.Models.Product

<div class="group bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">

    <div class="relative overflow-hidden">
        <img src="@Model.Image"
             class="w-full h-64 object-cover group-hover:scale-110 transition-transform duration-500" />

        <div class="absolute top-4 left-4 right-4 flex justify-between">
            <span class="bg-green-600 text-white text-xs font-semibold px-3 py-1 rounded-full">
                🌿 Eco-Friendly
            </span>

            <a asp-controller="Wishlist"
               asp-action="Add"
               asp-route-id="@Model.Id"
               class="bg-white text-red-600 p-2 rounded-full shadow-md hover:bg-red-50">
                ❤️
            </a>
        </div>

        <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-20 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all">
            <a asp-controller="Product"
               asp-action="Details"
               asp-route-id="@Model.Id"
               class="bg-white p-3 rounded-full hover:bg-gray-100">
                👁
            </a>
        </div>
    </div>

    <div class="p-5 space-y-3">

        <p class="text-xs text-green-600 font-semibold uppercase">
            @Model.Category
        </p>

        <h3 class="text-lg font-bold text-gray-900">
            @Model.Name
        </h3>

        <p class="text-sm text-gray-600">
            @Model.Description
        </p>

        <div class="flex items-center justify-between pt-3 border-t">
            <span class="text-2xl font-bold text-gray-900">
                ₹@Model.Price
            </span>

            <a asp-controller="Cart"
               asp-action="Add"
               asp-route-id="@Model.Id"
               class="bg-green-600 text-white p-3 rounded-full hover:bg-green-700">
                🛒
            </a>
        </div>
    </div>
</div>