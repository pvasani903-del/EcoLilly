@using Microsoft.AspNetCore.Http

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    var userName = Context.Session.GetString("UserName");
    var userEmail = Context.Session.GetString("UserEmail");
    var userProfile = Context.Session.GetString("UserProfileImage") ?? "/images/default-avatar.png";
}

<div class="max-w-7xl mx-auto mt-10 grid grid-cols-1 md:grid-cols-4 gap-6 px-4">

    <!-- LEFT SIDEBAR -->

    <div class="space-y-4">

        <!-- PROFILE CARD -->

        <div class="bg-purple-700 text-white rounded-xl p-6 text-center">

            <img src="@userProfile"
                 class="w-20 h-20 rounded-full mx-auto border-4 border-white object-cover mb-3" />

            <h3 class="font-bold text-lg">@userName</h3>

            <p class="text-sm">@userEmail</p>

        </div>

        <!-- MENU -->

        <div class="bg-white rounded-lg shadow">

            <a asp-controller="Home" asp-action="Index"
               class="block px-4 py-3 border-b hover:bg-gray-100">
                Home
            </a>

            <a asp-controller="Account" asp-action="Dashboard"
               class="block px-4 py-3 border-b hover:bg-gray-100">
                Dashboard
            </a>

            <a asp-controller="Account" asp-action="EditProfile"
               class="block px-4 py-3 border-b hover:bg-gray-100">
                Edit Profile
            </a>

            <a asp-controller="Account" asp-action="ChangePassword"
               class="block px-4 py-3 border-b hover:bg-gray-100">
                Change Password
            </a>

            <a asp-controller="Wishlist" asp-action="Index"
               class="block px-4 py-3 border-b hover:bg-gray-100">
                Wishlist
            </a>

            <a asp-controller="Cart" asp-action="Index"
               class="block px-4 py-3 border-b hover:bg-gray-100">
                Shopping Cart
            </a>

            <a asp-controller="Order" asp-action="Index"
               class="block px-4 py-3 hover:bg-gray-100">
                Order History
            </a>

        </div>

    </div>

    <!-- RIGHT CONTENT -->

    <div class="md:col-span-3">

        @RenderBody()

    </div>

</div>