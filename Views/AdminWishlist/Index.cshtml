@model IEnumerable<EcoLilly.Models.Wishlist>
@{
    ViewData["Title"] = "Customer Wishlists";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
        <h5 class="fw-bold"><i class="bi bi-heart text-danger me-2"></i> Wishlisted Items</h5>
    </div>
    <div class="card-body px-4">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>User Email</th>
                    <th>Product Name</th>
                    <th>Price</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var w in Model)
                {
                    <tr>
                        <td class="fw-bold">@w.UserEmail</td>
                        <td>@(w.Product?.Name ?? "Unknown")</td>
                        <td class="text-success fw-bold">₹@(w.Product?.Price ?? 0)</td>
                        <td class="text-end">
                            <form asp-action="Delete" asp-route-id="@w.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this from the wishlist?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>