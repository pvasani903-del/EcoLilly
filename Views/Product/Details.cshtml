@model EcoLilly.Models.Product

<section class="bg-white min-h-screen py-12">
    <div class="max-w-7xl mx-auto px-4">

        <a asp-action="Index" class="text-gray-600 hover:text-green-600 mb-8 inline-block">
            ← Back to Products
        </a>

        <div class="grid md:grid-cols-2 gap-12">

            <div>
                <img src="@Model.Image"
                     class="w-full h-[500px] object-cover rounded-2xl shadow-xl" />
            </div>

            <div class="space-y-6">

                <p class="text-sm text-green-600 font-semibold uppercase">
                    @Model.Category
                </p>

                <h1 class="text-4xl font-bold text-gray-900">
                    @Model.Name
                </h1>

                <div class="flex items-center space-x-4">
                    <span class="text-5xl font-bold text-gray-900">
                        ₹@Model.Price
                    </span>

                    @if (Model.InStock)
                    {
                        <span class="text-green-600 font-semibold">
                            ✔ In Stock
                        </span>
                    }
                    else
                    {
                        <span class="text-red-600 font-semibold">
                            Out of Stock
                        </span>
                    }
                </div>

                <p class="text-lg text-gray-600">
                    @Model.Description
                </p>

                <div>
                    <h3 class="text-lg font-bold text-gray-900">
                        🌿 Eco Features
                    </h3>

                    <ul class="mt-3 space-y-2">
                        @foreach (var feature in Model.EcoFeatures.Split(','))
                        {
                            <li class="text-gray-700">
                                ✔ @feature
                            </li>
                        }
                    </ul>
                </div>

                <div class="flex gap-4">
                    <a asp-controller="Cart"
                       asp-action="Add"
                       asp-route-id="@Model.Id"
                       class="flex-1 bg-green-600 text-white py-4 rounded-full text-center font-semibold hover:bg-green-700">
                        🛒 Add to Cart
                    </a>

                    <a asp-controller="Wishlist"
                       asp-action="Add"
                       asp-route-id="@Model.Id"
                       class="bg-red-50 text-red-600 px-6 py-4 rounded-full border-2 border-red-200">
                        ❤️ Save
                    </a>
                </div>

            </div>
        </div>

        <!-- ⭐ REVIEW SECTION -->
        <div class="mt-16">

            <h2 class="text-3xl font-bold mb-6">⭐ Customer Reviews</h2>

            <!-- ✅ ADD REVIEW FORM -->
            <div class="bg-gray-100 p-6 rounded-xl mb-10">
                <form asp-controller="Review" asp-action="AddReview" method="post" class="space-y-4">

                    <input type="hidden" name="ProductId" value="@Model.Id" />

                    <input type="text"
                           name="User"
                           placeholder="Your Name"
                           class="w-full p-3 border rounded-lg"
                           required />

                    <select name="Rating" class="w-full p-3 border rounded-lg">
                        <option value="1">⭐ 1</option>
                        <option value="2">⭐⭐ 2</option>
                        <option value="3">⭐⭐⭐ 3</option>
                        <option value="4">⭐⭐⭐⭐ 4</option>
                        <option value="5">⭐⭐⭐⭐⭐ 5</option>
                    </select>

                    <textarea name="Comment"
                              placeholder="Write your review..."
                              class="w-full p-3 border rounded-lg"
                              required></textarea>

                    <button type="submit"
                            class="bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700">
                        Submit Review
                    </button>
                </form>
            </div>

            <!-- ✅ SHOW REVIEWS -->
            @if (Model.Reviews != null && Model.Reviews.Any())
            {
                <div class="space-y-6">
                    @foreach (var review in Model.Reviews.OrderByDescending(r => r.Date))
                    {
                        <div class="border p-5 rounded-xl shadow-sm bg-white">

                            <div class="flex justify-between items-center">
                                <h4 class="font-bold text-lg">
                                    @review.User
                                </h4>

                                <span class="text-sm text-gray-500">
                                    @review.Date.ToString("dd MMM yyyy")
                                </span>
                            </div>

                            <p class="text-yellow-500 mt-1">
                                @for (int i = 0; i < review.Rating; i++)
                                {
                                    <span>⭐</span>
                                }
                            </p>

                            <p class="text-gray-700 mt-2">
                                @review.Comment
                            </p>

                            <!-- ❌ DELETE BUTTON -->
                            <a asp-controller="Review"
                               asp-action="Delete"
                               asp-route-id="@review.Id"
                               class="text-red-500 text-sm mt-3 inline-block">
                                Delete
                            </a>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-gray-500">No reviews yet. Be the first to review!</p>
            }

        </div>

    </div>
</section>