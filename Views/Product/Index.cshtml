@model IEnumerable<EcoLilly.Models.Product>
@{
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Products</h4>
    <div>
        <a asp-controller="Product" asp-action="Create" class="btn btn-primary">
            Add Product
        </a>
    </div>
</div>

<form method="get" class="mb-3">
    <div class="input-group">
        <input name="q" value="@Context.Request.Query["q"]" 
               class="form-control" placeholder="Search products..." />
        <button class="btn btn-outline-secondary">Search</button>
    </div>
</form>

<table class="table table-striped align-middle">
    <thead class="table-light">
        <tr>
            <th>#</th>
            <th>Image</th>
            <th>Name</th>
            <th>Price</th>
            <th>In Stock</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>

    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6" class="text-center text-muted">
                    No products found
                </td>
            </tr>
        }
        else
        {
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Id</td>

                    <!-- IMAGE: robust handling for filenames and full paths -->
                    <td>
                        @if (!string.IsNullOrEmpty(p.Image))
                        {
                            // If stored value already contains an absolute or root-relative path, use it.
                            // Otherwise assume images are placed under wwwroot/images/products/
                            var imgSrc = p.Image.StartsWith("/") || p.Image.StartsWith("http", System.StringComparison.OrdinalIgnoreCase)
                                         ? p.Image
                                         : Url.Content("~/images/products/" + p.Image);
                            var placeholder = Url.Content("~/images/no-image.png"); // put a placeholder at wwwroot/images/no-image.png

                            <img src="@imgSrc"
                                 style="height:50px; width:50px; object-fit:cover; border-radius:6px;"
                                 alt="@p.Name"
                                 onerror="this.onerror=null; this.src='@placeholder';" />
                        }
                        else
                        {
                            <img src="~/images/no-image.png"
                                 style="height:50px; width:50px; object-fit:cover; border-radius:6px;"
                                 alt="No image" />
                        }
                    </td>

                    <td>@p.Name</td>

                    <td class="fw-semibold text-success">
                        ₹@p.Price
                    </td>

                    <td>
                        @if (p.InStock)
                        {
                            <span class="badge bg-success">In Stock</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Out of Stock</span>
                        }
                    </td>

                    <td class="text-end">
                        <a asp-controller="Product" asp-action="Edit" asp-route-id="@p.Id"
                           class="btn btn-sm btn-warning">
                            Edit
                        </a>

                        <a asp-controller="Product" asp-action="Delete" asp-route-id="@p.Id"
                           class="btn btn-sm btn-danger"
                           onclick="return confirm('Are you sure you want to delete this product?');">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>