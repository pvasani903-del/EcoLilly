@model IEnumerable<EcoLilly.Models.Product>
@{
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Products</h4>
    <div>
        <a href="/Product/Create" class="btn btn-primary">Add Product</a>
    </div>
</div>

<form method="get" class="mb-3">
    <div class="input-group">
        <input name="q" value="@Context.Request.Query["q"]" class="form-control" placeholder="Search products..." />
        <button class="btn btn-outline-secondary">Search</button>
    </div>
</form>

<table class="table table-striped table-responsive">
    <thead>
        <tr>
            <th>#</th>
            <th>Image</th>
            <th>Name</th>
            <th>Price</th>
            <th>InStock</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Id</td>
                <td>
                    @if (!string.IsNullOrEmpty(p.Image))
                    {
                        <img src="@p.Image" style="height:48px;" />
                    }
                </td>
                <td>@p.Name</td>
                <td>₹@p.Price</td>
                <td>@(p.InStock ? "Yes" : "No")</td>
                <td>
                    <a class="btn btn-sm btn-warning" href="/Product/Edit/@p.Id">Edit</a>
                    <a class="btn btn-sm btn-danger" href="/Product/Delete/@p.Id" onclick="return confirm('Delete this product?');">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>