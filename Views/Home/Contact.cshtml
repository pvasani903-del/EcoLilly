@model EcoLilly.Models.Contact

@{
    ViewData["Title"] = "Contact";
}

<section class="py-16 bg-gradient-to-b from-white to-green-50 min-h-screen">
    <div class="max-w-7xl mx-auto px-4">

        <!-- Header -->
        <div class="text-center mb-16">
            <h2 class="text-4xl font-bold text-gray-900 mb-4">Get in Touch</h2>
            <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                Have questions about our products? We'd love to hear from you.
            </p>
        </div>

        <!-- Contact Info Cards -->
        <div class="grid md:grid-cols-3 gap-8 mb-16">

            <div class="bg-white rounded-lg shadow-md p-8 text-center">
                <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">
                    📧
                </div>
                <h3 class="text-xl font-bold mb-2">Email</h3>
                <p class="text-gray-600">hello@ecoliving.com</p>
            </div>

            <div class="bg-white rounded-lg shadow-md p-8 text-center">
                <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">
                    📞
                </div>
                <h3 class="text-xl font-bold mb-2">Phone</h3>
                <p class="text-gray-600">(555) 123-4567</p>
            </div>

            <div class="bg-white rounded-lg shadow-md p-8 text-center">
                <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">
                    📍
                </div>
                <h3 class="text-xl font-bold mb-2">Address</h3>
                <p class="text-gray-600">
                    123 Green Street <br />
                    Portland, OR 97201
                </p>
            </div>

        </div>

        <!-- Contact Form -->
        <div class="bg-white rounded-lg shadow-lg p-8">

            <h3 class="text-2xl font-bold mb-8">Send us a Message</h3>

            @if (ViewBag.Success != null)
            {
                <div class="mb-6 p-4 bg-green-100 border border-green-300 rounded-lg text-green-700">
                    @ViewBag.Success
                </div>
            }

            <form asp-action="Contact" method="post" class="space-y-6">

                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium mb-2">Your Name</label>
                        <input asp-for="Name"
                               class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-500" />
                        <span asp-validation-for="Name" class="text-red-500 text-sm"></span>
                    </div>

                    <div>
                        <label class="block text-sm font-medium mb-2">Email</label>
                        <input asp-for="Email"
                               class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-500" />
                        <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium mb-2">Subject</label>
                    <input asp-for="Subject"
                           class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-500" />
                    <span asp-validation-for="Subject" class="text-red-500 text-sm"></span>
                </div>

                <div>
                    <label class="block text-sm font-medium mb-2">Message</label>
                    <textarea asp-for="Message" rows="6"
                              class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-500"></textarea>
                    <span asp-validation-for="Message" class="text-red-500 text-sm"></span>
                </div>

                <button type="submit"
                        class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded-lg">
                    Send Message
                </button>

            </form>
        </div>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}