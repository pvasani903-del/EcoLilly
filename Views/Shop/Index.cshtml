@model List<EcoLilly.Models.Product>

@{
    var categories = ViewBag.Categories as List<string>;
    var currentCategory = Context.Request.Query["category"].ToString();
    var currentMinPrice = Context.Request.Query["minPrice"].ToString();
    var currentMaxPrice = Context.Request.Query["maxPrice"].ToString();
    var currentSearch = Context.Request.Query["q"].ToString();
}

<div class="max-w-7xl mx-auto px-4 py-10">

    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">

        <!-- FILTER PANEL -->
        <div class="md:col-span-3">

            <div class="bg-white p-5 rounded-xl shadow-md">

                <form method="get" asp-controller="Shop" asp-action="Index">

                    <h3 class="font-bold text-lg mb-4">Categories</h3>

                    <div class="space-y-2 mb-6">
                        <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="category" value="all" @(string.IsNullOrEmpty(currentCategory) || currentCategory == "all" ? "checked" : "")>
                                All Products
                            </label>

                        @if (categories != null)
                        {
                            foreach (var c in categories)
                            {
                                if (!string.IsNullOrEmpty(c))
                                {
                                    <label class="flex items-center gap-2 cursor-pointer">
                                        <input type="radio" name="category" value="@c" @(currentCategory == c ? "checked" : "")>
                                        @c
                                    </label>
                                }
                            }
                        }
                    </div>


                    <h3 class="font-bold text-lg mb-3">Price Range</h3>

                    <div class="flex gap-2 mb-6">
                        <input type="number"
                               name="minPrice"
                               value="@currentMinPrice"
                               placeholder="Min"
                               class="border p-2 w-1/2 rounded outline-none focus:border-green-500">

                        <input type="number"
                               name="maxPrice"
                               value="@currentMaxPrice"
                               placeholder="Max"
                               class="border p-2 w-1/2 rounded outline-none focus:border-green-500">
                    </div>


                    <h3 class="font-bold text-lg mb-3">Search</h3>

                    <input type="text"
                           name="q"
                           value="@currentSearch"
                           placeholder="Search product..."
                           class="border p-2 w-full rounded mb-6 outline-none focus:border-green-500">


                    <button type="submit"
                            class="w-full bg-green-600 text-white font-bold py-2 rounded-lg hover:bg-green-700 transition">
                        Apply Filters
                    </button>

                    <a asp-action="Index" class="block text-center w-full mt-3 text-gray-500 hover:text-gray-800 text-sm">
                        Clear All Filters
                    </a>

                </form>

            </div>

        </div>



        <!-- PRODUCTS -->
        <div class="md:col-span-9">

            @if (!Model.Any())
            {
                <div class="bg-white rounded-xl shadow-md p-10 text-center">
                    <h2 class="text-2xl font-bold text-gray-700 mb-2">No products found</h2>
                    <p class="text-gray-500">Try adjusting your filters or search keywords.</p>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

                    @foreach (var product in Model)
                    {
                        <div class="bg-white rounded-xl shadow-md p-4 hover:shadow-lg transition flex flex-col h-full relative">

                            <!-- WISHLIST -->
                            <a asp-controller="Wishlist"
                               asp-action="Add"
                               asp-route-id="@product.Id"
                               class="absolute top-3 right-3 bg-white/80 p-2 rounded-full text-gray-400 hover:text-red-500 shadow-sm transition">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                                </svg>
                            </a>

                            <!-- PRODUCT IMAGE -->
                            <a asp-controller="Shop" asp-action="Details" asp-route-id="@product.Id">
                                <img src="@(string.IsNullOrEmpty(product.Image) ? "/images/placeholder.jpg" : product.Image)"
                                     class="w-full h-48 object-cover rounded-lg mb-3" alt="@product.Name" />
                            </a>

                            <div class="flex-grow">
                                <p class="text-xs font-semibold text-green-600 uppercase tracking-wider mb-1">
                                    @product.Category
                                </p>

                                <h3 class="font-bold text-gray-800 text-lg mb-1 line-clamp-1 truncate">
                                    <a asp-controller="Shop" asp-action="Details" asp-route-id="@product.Id">@product.Name</a>
                                </h3>

                                <p class="text-gray-500 text-sm line-clamp-2 mb-3 h-10 overflow-hidden">
                                    @product.Description
                                </p>
                            </div>

                            <div class="mt-auto">
                                <div class="text-xl text-gray-900 font-bold mb-4">
                                    ₹@product.Price.ToString("0.00")
                                </div>

                                <!-- BUTTONS -->
                                <div class="flex gap-2">
                                    <form asp-controller="Cart" asp-action="AddToCart" method="post" class="flex-1">
                                        <input type="hidden" name="id" value="@product.Id" />
                                        <button type="submit" class="w-full bg-green-600 text-white text-center py-2 rounded-lg hover:bg-green-700 font-semibold text-sm transition">
                                            Add to Cart
                                        </button>
                                    </form>

                                    <a asp-controller="Shop"
                                       asp-action="Details"
                                       asp-route-id="@product.Id"
                                       class="flex-1 bg-gray-100 text-gray-800 text-center py-2 rounded-lg hover:bg-gray-200 font-semibold text-sm transition">
                                        Details
                                    </a>
                                </div>
                            </div>
                        </div>
                    }

                </div>
            }

        </div>

    </div>

</div>