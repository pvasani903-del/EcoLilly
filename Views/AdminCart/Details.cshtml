@model List<EcoLilly.Models.CartItem>
@{
    Layout = "_AdminLayout";
    var userEmail = ViewBag.UserEmail as string ?? "guest";
    var products = ViewBag.Products as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<!-- Top Header Section -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-cart-check text-primary me-2"></i> View Cart</h4>
        <div class="text-muted small">Viewing the active shopping cart for <span class="fw-bold text-dark">@userEmail</span></div>
    </div>
    
    <div>
        <a class="btn btn-light border px-4 shadow-sm fw-bold text-secondary me-2" asp-controller="AdminCart" asp-action="Index">
            <i class="bi bi-arrow-left"></i> Back
        </a>
        </div>
</div>

@if (TempData["success"] != null)
{
    <div class="alert alert-success py-2 shadow-sm rounded-3">@TempData["success"]</div>
}

<!-- Cart Items List -->
<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body px-4 pt-4">
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-cart-x fs-1 text-secondary opacity-50 mb-3 d-block"></i>
                <h5>Cart is empty</h5>
                <p>There are no items inside this user's cart yet.</p>
            </div>
        }
        else
        {
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Product Info</th>
                        <th class="text-end">Price</th>
                        <th class="text-center">Quantity</th>
                        <th class="text-end">Total Price</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (item.Product != null)
                                {
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@(string.IsNullOrEmpty(item.Product.Image) ? "/images/placeholder.jpg" : item.Product.Image)" 
                                             class="rounded shadow-sm border" style="height:50px; width:50px; object-fit:cover;" />
                                        <span class="fw-bold">@item.Product.Name</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted"><i class="bi bi-exclamation-triangle text-warning"></i> Product removed</span>
                                }
                            </td>
                            <td class="text-end text-muted">₹@((item.Product?.Price ?? 0m).ToString("N2"))</td>
                            
                            <!-- Quantity Controls -->
                            <td class="text-center fw-bold">
                                @item.Quantity
                            </td>

                            <td class="text-end fw-bold text-success">
                                ₹@(((item.Product?.Price ?? 0m) * item.Quantity).ToString("N2"))
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="mt-4 pt-3 border-top d-flex justify-content-end align-items-center gap-4">
                <div class="text-muted text-uppercase small fw-bold">Cart Subtotal:</div>
                <h3 class="fw-bold text-success m-0">₹@Model.Sum(i => (i.Product?.Price ?? 0m) * i.Quantity).ToString("N2")</h3>
            </div>
        }
    </div>
</div>