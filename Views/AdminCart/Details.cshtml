@model List<EcoLilly.Models.CartItem>
@{
    Layout = "_AdminLayout";
    var userEmail = ViewBag.UserEmail as string ?? "guest";
    var products = ViewBag.Products as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<div class="card mb-4">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <h4 class="m-0">Cart for <small class="text-muted">@userEmail</small></h4>
            <small class="text-muted">Manage this user's cart</small>
        </div>

        <div class="text-end">
            <form asp-controller="AdminCart" asp-action="Clear" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userEmail" value="@userEmail" />
                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Clear entire cart for @userEmail ?');">Clear Cart</button>
            </form>
            <a class="btn btn-sm btn-secondary ms-2" asp-controller="AdminCart" asp-action="Index">Back</a>
        </div>
    </div>
</div>

@if (TempData["success"] != null)
{
    <div class="alert alert-success">@TempData["success"]</div>
}

<div class="card mb-4">
    <div class="card-body">
        <h5 class="mb-3">Add Item</h5>
        <form asp-controller="AdminCart" asp-action="AddItem" method="post" class="row g-2 align-items-end">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userEmail" value="@userEmail" />
            <div class="col-md-6">
                <label class="form-label">Product</label>
                <select name="productId" class="form-select" required>
                    <option value="">-- Select product --</option>
                    @foreach (var p in products)
                    {
                        <option value="@p.Id">@p.Name (@string.Format("₹{0:N2}", p.Price))</option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Quantity</label>
                <input type="number" name="quantity" value="1" min="1" class="form-control" required />
            </div>

            <div class="col-md-2">
                <button class="btn btn-success w-100">Add</button>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No items for this user.</div>
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="text-end">Price</th>
                            <th style="width:220px;">Quantity</th>
                            <th class="text-end">Total</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @if (item.Product != null)
                                    {
                                        <div class="d-flex align-items-center gap-2">
                                            <img src="@item.Product.Image" style="height:48px; width:48px; object-fit:cover;" />
                                            <div>@item.Product.Name</div>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Product removed</span>
                                    }
                                </td>
                                <td class="text-end">₹@((item.Product?.Price ?? 0m).ToString("N2"))</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <form asp-controller="AdminCart" asp-action="DecreaseItem" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button class="btn btn-sm btn-outline-secondary">-</button>
                                        </form>

                                        <form asp-controller="AdminCart" asp-action="UpdateQuantity" method="post" class="m-0 ms-2 d-flex">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control form-control-sm" style="width:80px;" />
                                            <button class="btn btn-sm btn-primary ms-2" type="submit">Save</button>
                                        </form>

                                        <form asp-controller="AdminCart" asp-action="IncreaseItem" method="post" class="m-0 ms-2">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button class="btn btn-sm btn-outline-secondary">+</button>
                                        </form>

                                        <a class="btn btn-sm btn-outline-info ms-2" asp-controller="AdminCart" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                                    </div>
                                </td>
                                <td class="text-end">₹@(((item.Product?.Price ?? 0m) * item.Quantity).ToString("N2"))</td>
                                <td class="text-end">
                                    <form asp-controller="AdminCart" asp-action="Delete" method="post" class="m-0" onsubmit="return confirm('Remove item?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button class="btn btn-sm btn-danger">Remove</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-3 d-flex justify-content-between align-items-center">
                <a class="btn btn-secondary" asp-controller="AdminCart" asp-action="Index">Back</a>
                <div>
                    <strong>Grand Total: </strong>
                    ₹@Model.Sum(i => (i.Product?.Price ?? 0m) * i.Quantity).ToString("N2")
                </div>
            </div>
        </div>
    </div>
}