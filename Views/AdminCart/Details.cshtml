@model List<EcoLilly.Models.CartItem>
@{
    Layout = "_AdminLayout";
    var userEmail = ViewBag.UserEmail as string ?? "guest";
    var products = ViewBag.Products as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<!-- Top Header Section -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-cart-check text-primary me-2"></i> Edit Cart</h4>
        <div class="text-muted small">Managing the active shopping cart for <span class="fw-bold text-dark">@userEmail</span></div>
    </div>
    
    <div>
        <a class="btn btn-light border px-4 shadow-sm fw-bold text-secondary me-2" asp-controller="AdminCart" asp-action="Index">
            <i class="bi bi-arrow-left"></i> Back
        </a>
        <form asp-controller="AdminCart" asp-action="Clear" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userEmail" value="@userEmail" />
            <button type="submit" class="btn btn-danger px-4 shadow-sm fw-bold" onclick="return confirm('Clear entire cart for @userEmail ?');">
                <i class="bi bi-trash"></i> Clear All
            </button>
        </form>
    </div>
</div>

@if (TempData["success"] != null)
{
    <div class="alert alert-success py-2 shadow-sm rounded-3">@TempData["success"]</div>
}

<!-- Add Item Section -->
<div class="card shadow-sm border-0 rounded-4 mb-4 bg-light">
    <div class="card-body p-4">
        <h6 class="fw-bold mb-3"><i class="bi bi-plus-circle text-success me-1"></i> Add Product to Cart</h6>
        <form asp-controller="AdminCart" asp-action="AddItem" method="post" class="row g-3 align-items-end">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userEmail" value="@userEmail" />
            
            <div class="col-md-7">
                <label class="form-label small fw-bold text-secondary">Select Product</label>
                <select name="productId" class="form-select border-0 shadow-sm" required>
                    <option value="">-- Choose a product --</option>
                    @foreach (var p in products)
                    {
                        <option value="@p.Id">@p.Name (₹@string.Format("{0:N2}", p.Price))</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label small fw-bold text-secondary">Quantity</label>
                <input type="number" name="quantity" value="1" min="1" class="form-control border-0 shadow-sm" required />
            </div>

            <div class="col-md-2">
                <button class="btn btn-success w-100 fw-bold shadow-sm">Add Item</button>
            </div>
        </form>
    </div>
</div>

<!-- Cart Items List -->
<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body px-4 pt-4">
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-cart-x fs-1 text-secondary opacity-50 mb-3 d-block"></i>
                <h5>Cart is empty</h5>
                <p>There are no items inside this user's cart yet.</p>
            </div>
        }
        else
        {
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Product Info</th>
                        <th class="text-end">Price</th>
                        <th class="text-center">Manage Qty</th>
                        <th class="text-end">Total Price</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (item.Product != null)
                                {
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@(string.IsNullOrEmpty(item.Product.Image) ? "/images/placeholder.jpg" : item.Product.Image)" 
                                             class="rounded shadow-sm border" style="height:50px; width:50px; object-fit:cover;" />
                                        <span class="fw-bold">@item.Product.Name</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted"><i class="bi bi-exclamation-triangle text-warning"></i> Product removed</span>
                                }
                            </td>
                            <td class="text-end text-muted">₹@((item.Product?.Price ?? 0m).ToString("N2"))</td>
                            
                            <!-- Quantity Controls -->
                            <td>
                                <div class="d-flex justify-content-center align-items-center bg-light rounded-pill px-2 py-1 mx-auto" style="width: fit-content;">
                                    <form asp-controller="AdminCart" asp-action="DecreaseItem" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button class="btn btn-sm btn-link text-dark text-decoration-none fw-bold fs-5 px-2 py-0 border-0">-</button>
                                    </form>

                                    <form asp-controller="AdminCart" asp-action="UpdateQuantity" method="post" class="m-0 d-flex align-items-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control form-control-sm text-center bg-transparent border-0 fw-bold" style="width:50px; font-size:15px;" onchange="this.form.submit()" />
                                    </form>

                                    <form asp-controller="AdminCart" asp-action="IncreaseItem" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button class="btn btn-sm btn-link text-dark text-decoration-none fw-bold fs-5 px-2 py-0 border-0">+</button>
                                    </form>
                                </div>
                            </td>

                            <td class="text-end fw-bold text-success">
                                ₹@(((item.Product?.Price ?? 0m) * item.Quantity).ToString("N2"))
                            </td>
                            
                            <td class="text-end">
                                <form asp-controller="AdminCart" asp-action="Delete" method="post" class="m-0" onsubmit="return confirm('Remove item from cart?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-x-circle"></i> Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="mt-4 pt-3 border-top d-flex justify-content-end align-items-center gap-4">
                <div class="text-muted text-uppercase small fw-bold">Cart Subtotal:</div>
                <h3 class="fw-bold text-success m-0">₹@Model.Sum(i => (i.Product?.Price ?? 0m) * i.Quantity).ToString("N2")</h3>
            </div>
        }
    </div>
</div>