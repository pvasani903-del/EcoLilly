@model List<EcoLilly.Controllers.AdminCartUserViewModel>
@{
    ViewData["Title"] = "Active Carts";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
        <h5 class="fw-bold m-0"><i class="bi bi-cart3 text-success me-2"></i> Active Customer Carts</h5>

        <!-- Search Bar -->
        <form method="get" class="m-0" style="max-w: 300px;">
            <div class="input-group input-group-sm">
                <input name="search" value="@Context.Request.Query["search"]" class="form-control" placeholder="Search by email..." />
                <button class="btn btn-success"><i class="bi bi-search"></i> Search</button>
            </div>
        </form>
    </div>

    <div class="card-body px-4 pt-4">

        @if (TempData["success"] != null)
        {
            <div class="alert alert-success py-2">@TempData["success"]</div>
        }

        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>User Email</th>
                    <th>Total Items in Cart</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-4">No active carts found.</td>
                    </tr>
                }
                else
                {
                    foreach (var u in Model)
                    {
                        <tr>
                            <td class="fw-bold">@u.UserEmail</td>
                            <td><span class="badge bg-secondary">@u.ItemsCount Items</span></td>
                            <td class="text-end">
                                <!-- VIEW BUTTON (Details Action internally) -->
                                <a class="btn btn-sm btn-outline-info me-2" asp-controller="AdminCart" asp-action="Details" asp-route-userEmail="@u.UserEmail">
                                    <i class="bi bi-eye"></i> View
                                </a>

                                <!-- DELETE BUTTON (Clear Action internally) -->
                                <form asp-controller="AdminCart" asp-action="Clear" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userEmail" value="@u.UserEmail" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete all items inside @(u.UserEmail)\'s cart?');">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

    </div>
</div>