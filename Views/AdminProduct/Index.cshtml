@model IEnumerable<EcoLilly.Models.Product>

@{
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="m-0">Products</h4>
    <div class="d-flex gap-2">
        <a class="btn btn-primary" asp-controller="AdminProduct" asp-action="Create">Add Product</a>
    </div>
</div>

<form method="get" class="mb-3">
    <div class="input-group">
        <input name="search" value="@Context.Request.Query["search"]" class="form-control" placeholder="Search products..." />
        <button class="btn btn-outline-secondary">Search</button>
    </div>
</form>

@if (TempData["success"] != null)
{
    <div class="alert alert-success">@TempData["success"]</div>
}

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>#</th>
                <th>Image</th>
                <th>Name</th>
                <th class="text-end">Price</th>
                <th>Category</th>
                <th>Stock</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.Image))
                        {
                            <img src="@item.Image" style="height:48px; width:64px; object-fit:cover;" />
                        }
                    </td>
                    <td>@item.Name</td>
                    <td class="text-end">₹@item.Price.ToString("N2")</td>
                    <td>@item.Category</td>
                    <td>@(item.InStock ? "Yes" : "No")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-warning me-1" asp-controller="AdminProduct" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                        <a class="btn btn-sm btn-danger" asp-controller="AdminProduct" asp-action="Delete" asp-route-id="@item.Id" onclick="return confirm('Delete this product?');">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>