@model IEnumerable<EcoLilly.Models.Order>

@{
    ViewData["Title"] = "All Orders";
    Layout = "_AdminLayout";
}

@functions {
    private string BadgeClass(string? status)
    {
        if (string.IsNullOrWhiteSpace(status)) return "bg-secondary text-white";
        var s = status.Trim().ToLowerInvariant();
        return s switch
        {
            "paid" or "delivered" or "completed" or "success" => "bg-success text-white",
            "failed" or "fail" or "cancelled" or "refunded" or "declined" => "bg-danger text-white",
            "pending" => "bg-warning text-dark",
            _ => "bg-warning text-dark"
        };
    }
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
        <h5 class="fw-bold">All Orders</h5>

        <form method="get" class="m-0" style="max-width: 360px;">
            <div class="input-group input-group-sm">
                <input name="search" value="@Context.Request.Query["search"]" class="form-control" placeholder="Search..." />
                <button class="btn btn-success">Search</button>
            </div>
        </form>
    </div>

    <div class="card-body px-4">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Order ID</th>
                    <th>Customer Name</th>
                    <th>Email</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Payment</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model)
                {
                    <tr>
                        <td class="fw-bold">#@o.Id.ToString("D4")</td>
                        <td>@o.CustomerName</td>
                        <td>@o.UserEmail</td>
                        <td>@o.OrderDate.ToString("MMM dd, yyyy")</td>
                        <td class="fw-bold text-success">₹@o.TotalAmount</td>
                        <td>@o.PaymentMethod</td>
                        <td>
                            <span class="badge @(BadgeClass(o.PaymentStatus))">
                                @o.PaymentStatus
                            </span>
                        </td>
                        <td class="text-end">
                            <form asp-action="Delete" asp-route-id="@o.Id" method="post" 
                                  onsubmit="return confirm('Delete this order?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>