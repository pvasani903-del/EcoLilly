@model IEnumerable<EcoLilly.Models.Order>
@{
    ViewData["Title"] = "All Orders";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
        <h5 class="fw-bold"><i class="bi bi-bag-check text-primary me-2"></i> All Orders</h5>
    </div>
    <div class="card-body px-4">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Order ID</th>
                    <th>Customer Name</th>
                    <th>Email</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Payment</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model)
                {
                    <tr>
                        <td class="fw-bold">#@o.Id</td>
                        <td>@o.CustomerName</td>
                        <td>@o.UserEmail</td>
                        <td>@o.OrderDate.ToString("MMM dd, yyyy")</td>
                        <td class="fw-bold text-success">₹@o.TotalAmount</td>
                        <td>@o.PaymentMethod</td>
                        <td><span class="badge bg-@(o.PaymentStatus == "Paid" ? "success" : "warning text-dark")">@o.PaymentStatus</span></td>
                        <td class="text-end">
                            <form asp-action="Delete" asp-route-id="@o.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this order?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>