@model List<EcoLilly.Models.Order>

@{
    ViewData["Title"] = "My Orders";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="container mt-4">

    <h2 class="text-2xl font-bold mb-6">
        My Orders
    </h2>

    @if (Model == null || !Model.Any())
    {
        <div class="bg-white p-6 rounded shadow text-center">

            <h3 class="text-lg font-semibold mb-2">
                No Orders Yet
            </h3>

            <p class="text-gray-500 mb-4">
                You have not placed any orders yet.
            </p>

            <a asp-controller="Shop"
               asp-action="Index"
               class="bg-green-600 text-white px-4 py-2 rounded">
                Start Shopping
            </a>

        </div>
    }
    else
    {
        @foreach (var order in Model)
        {

            <div class="bg-white shadow rounded-xl p-6 mb-4 flex justify-between items-center">

                <div>

                    <h3 class="font-semibold">
                        Order #@order.Id
                    </h3>

                    <p class="text-gray-500">
                        Date: @order.OrderDate.ToString("dd MMM yyyy")
                    </p>

                </div>

                <div class="text-right">

                    <p class="font-bold text-lg text-green-600">
                        ₹@order.TotalAmount
                    </p>

                    <span class="px-3 py-1 rounded bg-gray-200 text-sm">
                        @order.PaymentStatus
                    </span>

                </div>

            </div>

        }
    }

</div>