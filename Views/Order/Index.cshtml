@model IEnumerable<EcoLilly.Models.Order>

@{
    ViewData["Title"] = "My Orders";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="container mt-4">

    <h2 class="text-2xl font-bold mb-6">
        My Orders
    </h2>

    @if (!Model.Any())
    {
        <div class="bg-white p-6 rounded shadow text-center">

            <h3 class="text-lg font-semibold mb-2">
                No Orders Yet
            </h3>

            <p class="text-gray-500 mb-4">
                You have not placed any orders yet.
            </p>

            <a asp-controller="Shop"
               asp-action="Index"
               class="bg-green-600 text-white px-4 py-2 rounded">
                Start Shopping
            </a>

        </div>
    }
    else
    {
        foreach (var order in Model)
        {
            <div class="card mb-3">
                <div class="card-header">
                    <strong>Order #@order.Id</strong> - @order.OrderDate.ToString("MMM dd, yyyy") | Total: $@order.TotalAmount
                </div>
                <div class="card-body">
                    <ul>
                        @foreach (var item in order.OrderItems)
                        {
                            <li>
                                @item.Product.Name - Quantity: @item.Quantity

                                @{
                                    // Check if this specific user has reviewed this product
                                    var userReview = item.Product.Reviews?.FirstOrDefault(r => r.User == order.UserEmail);
                                }

                                @if (userReview != null)
                                {
                                    <div class="alert alert-info mt-2 p-2">
                                        <strong>Your Review (@userReview.Rating/5):</strong> @userReview.Comment
                                        <br /><small class="text-muted">Reviewed on: @userReview.Date.ToString("MMM dd, yyyy")</small>
                                    </div>
                                }
                                else
                                {
                                    // Show a button linking to a page where they can create the review
                                    <a href="@Url.Action("Create", "Review", new { productId = item.ProductId })" class="btn btn-sm btn-outline-primary mt-2">
                                        Write a Review
                                    </a>
                                }
                            </li>
                        }
                    </ul>
                </div>
            </div>
        }
    }

</div>